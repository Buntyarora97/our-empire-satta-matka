{
  "expo": {
    "name": "Our Empire - Satta Matka",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ourempire",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "backgroundColor": "#0a0a0a",
      "package": "com.ourempire.sattamatka",
      "versionCode": 2
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "backgroundColor": "#0a0a0a"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "cbfb43b9-6fe0-4065-9346-c99e6a2ea7fe"
      }
    }
  }
}
